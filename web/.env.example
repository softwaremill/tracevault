# Backend API server URL (used by the frontend server-side proxy)
PUBLIC_API_URL=http://localhost:3000

# Frontend server port (default: 4000)
WEB_PORT=4000

# Frontend server host (default: 0.0.0.0)
WEB_HOST=0.0.0.0

# Set to the public-facing URL for CSRF protection
# ORIGIN=https://your-domain.com

# Date locale for formatting (default: en-US). Examples: sv-SE, en-GB, de-DE
# PUBLIC_DATE_LOCALE=en-US
